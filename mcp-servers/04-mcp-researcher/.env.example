# mcp-researcher environment configuration
# Copy to `.env` and fill in the values you want to override.

# ── Runtime ──────────────────────────────────────────────────────
# Transport: stdio | streamable-http | sse
MCP_RESEARCHER_TRANSPORT=stdio
MCP_RESEARCHER_HOST=127.0.0.1
MCP_RESEARCHER_PORT=9104
MCP_RESEARCHER_LOG_LEVEL=INFO

# ── arXiv ────────────────────────────────────────────────────────
ARXIV_MAX_RESULTS=8
ARXIV_DEFAULT_SORT=relevance         # relevance | submittedDate | lastUpdatedDate
ARXIV_REQUEST_TIMEOUT_S=30

# ── Paper reading / cache ───────────────────────────────────────
PAPER_CACHE_DIR=.cache/papers
ENABLE_PDF_DOWNLOAD=true
MAX_PDF_MB=50

# ── RAG / vector store (sprint 3) ───────────────────────────────
VECTOR_DB_DIR=.cache/chroma
MAX_CHUNKS_PER_QUERY=12

# ── WatsonX (sprint 3) ──────────────────────────────────────────
WATSONX_APIKEY=
WATSONX_URL=
WATSONX_PROJECT_ID=
WATSONX_MODEL_ID=meta-llama/llama-3-70b-instruct

# ── Safety limits ───────────────────────────────────────────────
MAX_PAPERS_PER_REQUEST=10
