{
  "schema_version": 1,
  "servers": [
    {
      "name": "mcp-exam-coach",
      "description": "MCP server for the Exam Coach persona.",
      "default_port": 9108,
      "url": "http://localhost:9108",
      "auth_type": "open",
      "registry_id": "mcp-exam-coach",
      "source": {
        "type": "registry",
        "registry_id": "mcp-exam-coach"
      },
      "transport": "HTTP",
      "protocol": "MCP",
      "health_endpoint": "/health",
      "tools_endpoint": "/tools",
      "tools_provided": [
        "exam_question",
        "exam_plan",
        "exam_explain"
      ]
    }
  ]
}
