{
  "schema_version": 1,
  "servers": [
    {
      "name": "mcp-storyteller",
      "description": "MCP server for the Storyteller persona.",
      "default_port": 9107,
      "url": "http://localhost:9107",
      "auth_type": "open",
      "registry_id": "mcp-storyteller",
      "source": {
        "type": "external",
        "git": "https://github.com/HomePilotAI/personas",
        "ref": "main",
        "subdir": "mcp-servers/07-mcp-storyteller",
        "registry_id": "mcp-storyteller"
      },
      "transport": "HTTP",
      "protocol": "MCP",
      "health_endpoint": "/health",
      "tools_endpoint": "/tools",
      "tools_provided": [
        "story_scene",
        "story_choice",
        "story_ending"
      ],
      "install": {
        "source_type": "external",
        "source_repo": "https://github.com/HomePilotAI/personas",
        "source_ref": "main",
        "source_subdir": "mcp-servers/07-mcp-storyteller",
        "runtime": "node",
        "install_cmd": "(cd ../../ && npm install --include=dev) && (npm install || true)",
        "start_cmd": "PORT={PORT} MCP_TRANSPORT=streamable-http MCP_PORT={PORT} node src/index.js",
        "health_url": "http://127.0.0.1:{PORT}/mcp",
        "default_port": 9107,
        "transport": "streamable-http",
        "env_required": []
      }
    }
  ]
}
