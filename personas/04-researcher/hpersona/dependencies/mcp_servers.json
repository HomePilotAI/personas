{
  "schema_version": 1,
  "servers": [
    {
      "name": "mcp-researcher",
      "description": "Python-native MCP server for academic research (arXiv search, paper reading, summaries, comparisons, literature briefs).",
      "default_port": 9104,
      "url": "http://localhost:9104",
      "auth_type": "open",
      "registry_id": "mcp-researcher",
      "source": {
        "type": "external",
        "git": "https://github.com/HomePilotAI/personas",
        "ref": "main",
        "subdir": "mcp-servers/04-mcp-researcher",
        "registry_id": "mcp-researcher"
      },
      "transport": "streamable-http",
      "protocol": "MCP",
      "health_endpoint": "/health",
      "tools_endpoint": "/tools",
      "mcp_endpoint": "/mcp",
      "tools_provided": [
        "search_arxiv",
        "read_paper",
        "summarize_paper",
        "compare_papers",
        "build_literature_brief"
      ],
      "install": {
        "source_type": "external",
        "source_repo": "https://github.com/HomePilotAI/personas",
        "source_ref": "main",
        "source_subdir": "mcp-servers/04-mcp-researcher",
        "runtime": "python",
        "install_cmd": "python -m pip install -e \".[dev]\"",
        "start_cmd": "python -m researcher.server --transport streamable-http --host 127.0.0.1 --port {PORT}",
        "health_url": "http://127.0.0.1:{PORT}/mcp",
        "default_port": 9104,
        "transport": "streamable-http",
        "env_required": []
      }
    }
  ]
}
