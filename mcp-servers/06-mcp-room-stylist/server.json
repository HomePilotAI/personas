{
  "name": "mcp-room-stylist",
  "description": "MCP server for the Room Stylist persona.",
  "default_port": 9106,
  "protocol": "HTTP",
  "transport": "HTTP",
  "version": "1.0.0",
  "health_endpoint": "/health",
  "tools_endpoint": "/tools",
  "auth_type": "open",
  "tools": [
    {
      "name": "room_layout",
      "description": "Proposes 2-3 room layout options."
    },
    {
      "name": "room_palette",
      "description": "Generates a 60/30/10 colour palette."
    },
    {
      "name": "room_shopping_list",
      "description": "Builds a shoppable list at 3 price tiers."
    }
  ]
}
