{
  "name": "mcp-mindfulness-coach",
  "description": "MCP server for the Mindfulness Coach persona.",
  "default_port": 9109,
  "protocol": "HTTP",
  "transport": "HTTP",
  "version": "1.0.0",
  "health_endpoint": "/health",
  "tools_endpoint": "/tools",
  "auth_type": "open",
  "tools": [
    {
      "name": "mindfulness_meditation",
      "description": "Generates a guided meditation script."
    },
    {
      "name": "mindfulness_grounding",
      "description": "Leads a 5-4-3-2-1 grounding exercise."
    },
    {
      "name": "mindfulness_focus",
      "description": "Runs a short focus / breathing session."
    }
  ]
}
