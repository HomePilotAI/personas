{
  "name": "mcp-personal-trainer",
  "description": "MCP server for the Personal Trainer persona.",
  "default_port": 9105,
  "protocol": "HTTP",
  "transport": "HTTP",
  "version": "1.0.0",
  "health_endpoint": "/health",
  "tools_endpoint": "/tools",
  "auth_type": "open",
  "tools": [
    {
      "name": "trainer_workout_plan",
      "description": "Generates a periodised workout plan."
    },
    {
      "name": "trainer_recovery_check",
      "description": "Assesses recovery readiness."
    },
    {
      "name": "trainer_streak",
      "description": "Tracks training streaks and deloads."
    }
  ]
}
