# mcp-general-doctor — General Doctor safety adapter
# Copy to .env and override anything you don't want at the defaults.

# ── Runtime ───────────────────────────────────────────────────────────
# Transport: stdio | streamable-http | sse | legacy-http | hybrid
#   stdio           — local development / MCP Inspector
#   streamable-http — canonical MCP /mcp endpoint (recommended)
#   sse             — older MCP transport
#   legacy-http     — REST + /context-forge/call (no /mcp); use when
#                     deployment is REST-only Context Forge
#   hybrid          — FastMCP /mcp PLUS legacy REST routes on the same
#                     port (good migration-window choice)
DOCTOR_MCP_TRANSPORT=stdio
DOCTOR_MCP_HOST=127.0.0.1
DOCTOR_MCP_PORT=9110
DOCTOR_LOG_LEVEL=INFO

# Adapter feature flag — when false, the adapter refuses to register tools
# (used during rollback). The persona dependency stays valid; calls fail.
GENERAL_DOCTOR_ADAPTER_ENABLED=true

# ── Upstream medical-mcp-toolkit ─────────────────────────────────────
# https://github.com/ruslanmv/medical-mcp-toolkit
MEDICAL_MCP_URL=http://localhost:9090
MEDICAL_MCP_BEARER_TOKEN=
MEDICAL_MCP_TIMEOUT_S=10
# When the upstream is unreachable, fall back to the deterministic local fake
# so emergency screening (red flags) keeps working. Set to false in production
# if you'd rather hard-fail.
MEDICAL_MCP_OFFLINE_FALLBACK=true

# ── Tool exposure (defence-in-depth flags) ───────────────────────────
# These mirror docs/medical/medical-ai-safety-policy.md §5. Adapter refuses
# to expose them publicly regardless of any future code change.
ENABLE_PATIENT_TOOLS=false
ENABLE_DRUG_ALTERNATIVES=false
ENABLE_APPOINTMENT_SCHEDULING=false

# ── Audit logging ─────────────────────────────────────────────────────
# event-level logs only; raw user health text is hashed by default.
DOCTOR_AUDIT_LOG_PATH=
DOCTOR_AUDIT_HASH_USER_INPUT=true
